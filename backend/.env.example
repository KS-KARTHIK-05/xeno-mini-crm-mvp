# ============================================================
# Xeno Mini CRM — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Supabase PostgreSQL connection string
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@db.your_project_ref.supabase.co:5432/postgres

# Google Gemini API key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Channel Service URL (the stub service)
# Local dev: http://localhost:8001
# Production: https://your-channel-service.onrender.com
CHANNEL_SERVICE_URL=http://localhost:8001

# This CRM's own public URL (used by channel service to POST receipts back)
# Local dev: http://localhost:8000
# Production: https://your-crm-backend.onrender.com
CRM_CALLBACK_URL=http://localhost:8000

# CORS origin for the frontend
# Local dev: http://localhost:5173
# Production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
